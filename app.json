{
  "expo": {
    "name": "KAAR",
    "slug": "kaar",
    "version": "0.1.0",
    "scheme": "kaar",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/generated/icon.png",
    "splash": {
      "image": "./assets/generated/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#11131d"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "bundleIdentifier": "com.trijbs.kaar",
      "supportsTablet": true
    },
    "android": {
      "package": "com.trijbs.kaar",
      "adaptiveIcon": {
        "foregroundImage": "./assets/generated/adaptive-icon.png",
        "backgroundColor": "#11131d"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-asset"
    ]
  }
}
